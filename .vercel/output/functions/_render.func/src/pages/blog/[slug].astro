---
import Layout from "../../layouts/Layout.astro";
import Navigation from "../../components/Navigation.astro";
import Footer from "../../components/Footer.astro";
import PortableText from "../../components/PortableText.astro";
import { loadQuery } from "../../sanity/lib/load-query";
import { urlForImage } from "../../sanity/lib/url-for-image";

export async function getStaticPaths() {
  const { data: posts } = await loadQuery<any[]>({
    query: `*[_type == "post"]{ slug }`,
  });

  return posts.map(({ slug }) => {
    return {
      params: {
        slug: slug.current,
      },
    };
  });
}

const { params } = Astro;

const { data: post } = await loadQuery<any>({
  query: `*[_type == "post" && slug.current == $slug][0] {
    title,
    slug,
    publishedAt,
    excerpt,
    mainImage,
    body,
    author->{ name },
    categories[]->{ title }
  }`,
  params,
});

if (!post) {
  Astro.redirect('/404');
}

const formatDate = (dateString: string) => {
  const date = new Date(dateString);
  return date.toLocaleDateString("en-US", {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
};

const mainImageUrl = post?.mainImage ? urlForImage(post.mainImage).url() : null;

const pageTitle = post?.title || "Blog Post";
---

<Layout title={pageTitle}>
  <Navigation />
  <main class="flex-1 pt-20">
    <article class="min-h-screen">
      <div class="lg:hidden">
        <div class="bg-white px-6 py-8">
          <div class="max-w-3xl mx-auto space-y-4">
            {post?.categories && post.categories.length > 0 && (
              <div class="inline-block bg-warm-gold/10 text-warm-gold px-3 py-1 rounded-pill text-xs font-body font-semibold uppercase tracking-wider">
                {post.categories[0].title}
              </div>
            )}
            
            <h1 class="font-heading text-3xl md:text-4xl font-bold text-forest-green leading-tight">
              {post?.title}
            </h1>
            
            {post?.excerpt && (
              <p class="font-body text-lg text-muted-text leading-relaxed">
                {post.excerpt}
              </p>
            )}
            
            <div class="flex items-center gap-4 pt-2">
              {post?.author && (
                <div class="flex items-center gap-2">
                  <div class="w-8 h-8 rounded-full bg-forest-green flex items-center justify-center">
                    <span class="text-white font-body font-bold text-sm">
                      {post.author.name.charAt(0)}
                    </span>
                  </div>
                  <span class="font-body text-sm font-medium text-forest-green">
                    {post.author.name}
                  </span>
                </div>
              )}
              
              {post?.publishedAt && (
                <time class="font-body text-sm text-muted-text" datetime={post.publishedAt}>
                  {formatDate(post.publishedAt)}
                </time>
              )}
            </div>
            
            <div class="flex items-center gap-3 pt-4">
              <button class="w-10 h-10 rounded-full border-2 border-forest-green/20 flex items-center justify-center hover:bg-forest-green/5 transition-colors">
                <svg class="w-5 h-5 text-forest-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                </svg>
              </button>
              <button class="w-10 h-10 rounded-full border-2 border-forest-green/20 flex items-center justify-center hover:bg-forest-green/5 transition-colors">
                <svg class="w-5 h-5 text-forest-green" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              </button>
              <button class="w-10 h-10 rounded-full border-2 border-forest-green/20 flex items-center justify-center hover:bg-forest-green/5 transition-colors">
                <svg class="w-5 h-5 text-forest-green" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                </svg>
              </button>
            </div>
          </div>
        </div>
        
        {mainImageUrl && (
          <div class="w-full">
            <img 
              src={mainImageUrl} 
              alt={post?.title} 
              class="w-full h-auto object-cover"
            />
          </div>
        )}
      </div>

      <div class="hidden lg:block">
        <div class="max-w-7xl mx-auto px-6 lg:px-12 py-12">
          <div class="flex gap-12">
            <aside class="w-32 flex-shrink-0 sticky top-28 h-fit">
              <div class="space-y-6">
                {post?.author && (
                  <div class="space-y-2">
                    <div class="font-body text-xs text-muted-text uppercase tracking-wide">Written by</div>
                    <div class="flex flex-col items-start gap-2">
                      <div class="w-12 h-12 rounded-full bg-forest-green flex items-center justify-center text-white font-heading font-bold text-lg">
                        {post.author.name.charAt(0)}
                      </div>
                      <span class="font-body text-sm font-semibold text-forest-green">
                        {post.author.name}
                      </span>
                    </div>
                  </div>
                )}
                
                {post?.publishedAt && (
                  <div class="space-y-1">
                    <div class="font-body text-xs text-muted-text uppercase tracking-wide">Published</div>
                    <time class="font-body text-sm text-near-black" datetime={post.publishedAt}>
                      {formatDate(post.publishedAt)}
                    </time>
                  </div>
                )}
                
                <div class="space-y-1">
                  <div class="font-body text-xs text-muted-text uppercase tracking-wide">Share</div>
                  <div class="flex flex-col gap-2">
                    <button class="w-10 h-10 rounded-full border-2 border-forest-green/20 flex items-center justify-center hover:bg-forest-green hover:text-white transition-colors group">
                      <svg class="w-5 h-5 text-forest-green group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                      </svg>
                    </button>
                    <button class="w-10 h-10 rounded-full border-2 border-forest-green/20 flex items-center justify-center hover:bg-forest-green hover:text-white transition-colors group">
                      <svg class="w-5 h-5 text-forest-green group-hover:text-white" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                      </svg>
                    </button>
                    <button class="w-10 h-10 rounded-full border-2 border-forest-green/20 flex items-center justify-center hover:bg-forest-green hover:text-white transition-colors group">
                      <svg class="w-5 h-5 text-forest-green group-hover:text-white" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                      </svg>
                    </button>
                  </div>
                </div>
              </div>
            </aside>

            <main class="flex-1 max-w-3xl">
              {post?.categories && post.categories.length > 0 && (
                <div class="mb-6">
                  <span class="inline-block bg-warm-gold/10 text-warm-gold px-3 py-1 rounded-pill text-xs font-body font-semibold uppercase tracking-wider">
                    {post.categories[0].title}
                  </span>
                </div>
              )}
              
              <h1 class="font-heading text-4xl lg:text-5xl font-bold text-forest-green leading-tight mb-6">
                {post?.title}
              </h1>
              
              {post?.excerpt && (
                <p class="font-body text-xl text-muted-text leading-relaxed mb-8">
                  {post.excerpt}
                </p>
              )}
              
              {mainImageUrl && (
                <div class="mb-10 rounded-card overflow-hidden">
                  <img 
                    src={mainImageUrl} 
                    alt={post?.title} 
                    class="w-full h-auto object-cover"
                  />
                </div>
              )}
              
              <div class="article-content font-body text-lg text-near-black leading-relaxed">
                {post?.body && <PortableText portableText={post.body} />}
              </div>
            </main>
          </div>
        </div>
      </div>
      
      <div class="lg:hidden px-6 py-8 bg-cream">
        <div class="max-w-3xl mx-auto">
          <div class="article-content font-body text-base text-near-black leading-relaxed">
            {post?.body && <PortableText portableText={post.body} />}
          </div>
        </div>
      </div>
    </article>
  </main>
  <Footer />
</Layout>

<style>
  .article-content :global(h1) {
    @apply font-heading text-2xl font-bold text-forest-green mt-8 mb-4;
  }
  .article-content :global(h2) {
    @apply font-heading text-xl font-bold text-forest-green mt-6 mb-3;
  }
  .article-content :global(h3) {
    @apply font-heading text-lg font-semibold text-forest-green mt-5 mb-2;
  }
  .article-content :global(h4) {
    @apply font-heading text-base font-semibold text-forest-green mt-4 mb-2;
  }
  .article-content :global(p) {
    @apply mb-4 leading-relaxed;
  }
  .article-content :global(blockquote) {
    @apply border-l-4 border-warm-gold pl-4 py-2 my-6 bg-forest-green/5 rounded-r-lg;
  }
  .article-content :global(blockquote p) {
    @apply italic text-forest-green m-0;
  }
  .article-content :global(a) {
    @apply text-warm-gold hover:text-forest-green underline underline-offset-2;
  }
  .article-content :global(ul),
  .article-content :global(ol) {
    @apply my-4 pl-6;
  }
  .article-content :global(ul) {
    @apply list-disc;
  }
  .article-content :global(ol) {
    @apply list-decimal;
  }
  .article-content :global(li) {
    @apply mb-2;
  }
  .article-content :global(img) {
    @apply rounded-card my-6 w-full;
  }
  .article-content :global(pre) {
    @apply bg-forest-green text-white p-4 rounded-card my-6 overflow-x-auto;
  }
  .article-content :global(code) {
    @apply bg-forest-green/10 text-forest-green px-1 py-0.5 rounded text-sm;
  }
  .article-content :global(pre code) {
    @apply bg-transparent p-0;
  }
  .article-content :global(strong) {
    @apply font-semibold text-forest-green;
  }
  .article-content :global(em) {
    @apply italic;
  }
  .article-content :global(hr) {
    @apply border-t border-rule-border my-8;
  }
  .article-content :global(table) {
    @apply w-full my-6 border-collapse;
  }
  .article-content :global(th) {
    @apply bg-forest-green text-white font-semibold text-left p-3;
  }
  .article-content :global(td) {
    @apply border border-rule-border p-3;
  }
  .article-content :global(tr:nth-child(even)) {
    @apply bg-cream;
  }
</style>
