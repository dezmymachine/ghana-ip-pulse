---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import { loadQuery } from "../sanity/lib/load-query";

const { data: events } = await loadQuery<any[]>({
  query: `*[_type == "event"] | order(date asc)`,
});

const formatDateParts = (dateString: string) => {
  const date = new Date(dateString);
  return {
    day: date.getDate().toString().padStart(2, "0"),
    month: date.toLocaleDateString("en-US", { month: "short" }),
    year: date.getFullYear().toString(),
  };
};

const pastEvents: { date: string; title: string; attendees: string }[] = [];
---

<Layout title="Events">
  <Navigation />
  <main class="flex-1 pt-24 lg:pt-28">
    <div class="bg-cream">
      <section class="py-20">
        <div class="max-w-7xl mx-auto px-6 lg:px-12">
          <h2 class="text-4xl font-bold text-forest-green mb-12 animate-on-scroll">
            Upcoming Events
          </h2>

          <div class="space-y-6">
            {events?.length > 0 ? (events.map((event: any, index: number) => {
              const dateParts = formatDateParts(event.date);
              const isFeatured = index === 0;
              return (
                <article
                  class={`bg-white border-l-4 ${
                    isFeatured ? "border-warm-gold" : "border-forest-green"
                  } border-r border-t border-b border-rule-border hover:shadow-[6px_6px_0px_0px_rgba(26,60,46,0.1)] transition-all group rounded-lg animate-on-scroll`}
                  data-delay={String(index + 1)}
                >
                  <div class="grid lg:grid-cols-[auto_1fr_auto] gap-8 p-8 lg:p-10">
                    <div class="flex flex-col items-center justify-center bg-forest-green text-white px-8 py-6 min-w-[140px] rounded-lg">
                      <div class="text-5xl font-bold leading-none">
                        {dateParts.day}
                      </div>
                      <div class="text-sm uppercase tracking-wider mt-1">
                        {dateParts.month}
                      </div>
                      <div class="text-sm tracking-wider text-warm-gold">
                        {dateParts.year}
                      </div>
                    </div>

                    <div>
                      {isFeatured && (
                        <div class="mb-3">
                          <span class="bg-warm-gold text-near-black px-3 py-1 text-xs uppercase tracking-wider rounded-pill">
                            Featured Event
                          </span>
                        </div>
                      )}
                      <div class="mb-2">
                        <span class="text-xs uppercase tracking-wider text-muted-text">
                          {event.type}
                        </span>
                      </div>
                      <h3 class="text-3xl text-near-black mb-4 group-hover:text-forest-green transition-colors">
                        {event.title}
                      </h3>
                      <p class="text-base text-muted-text leading-relaxed mb-6">
                        {event.description ? event.description : ""}
                      </p>

                      <div class="flex flex-wrap gap-6 text-sm text-muted-text">
                        <div class="flex items-center gap-2">
                          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-warm-gold"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                          {event.location}
                        </div>
                      </div>
                    </div>

                    <div class="flex flex-col justify-center">
                      <div class="mb-4">
                         <span class="text-xs uppercase tracking-wider text-forest-green bg-cream px-3 py-2 border border-rule-border rounded-pill">
                          Open for Registration
                        </span>
                      </div>
                      {event.registrationLink && (
                        <a
                          href={event.registrationLink}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="bg-forest-green text-white px-6 py-4 text-sm uppercase tracking-wider hover:bg-warm-gold hover:text-near-black transition-all inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-pill"
                        >
                          Register Now
                          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                        </a>
                      )}
                    </div>
                  </div>
                </article>
              );
            })) : (
              <div class="bg-white border-2 border-rule-border rounded-lg p-8 lg:p-12 text-center animate-on-scroll">
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-text mx-auto mb-4"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
                <p class="text-muted-text text-lg">No upcoming events at the moment. Check back soon!</p>
              </div>
            )}
          </div>
        </div>
      </section>

      <section class="py-20 border-t-2 border-rule-border">
        <div class="max-w-7xl mx-auto px-6 lg:px-12">
          <h2 class="text-4xl font-bold text-forest-green mb-12 animate-on-scroll">
            Past Events
          </h2>

          <div class="bg-white border-2 border-rule-border rounded-lg overflow-hidden animate-on-scroll">
            {pastEvents.length > 0 ? (pastEvents.map((event, index) => (
              <div
                class={`grid md:grid-cols-3 gap-4 items-center p-6 ${
                  index !== pastEvents.length - 1 ? "border-b-2 border-rule-border" : ""
                }`}
              >
                <div class="text-sm uppercase tracking-wider text-muted-text">
                  {event.date}
                </div>
                <div class="text-xl text-near-black">
                  {event.title}
                </div>
                <div class="text-base text-muted-text">
                  {event.attendees}
                </div>
              </div>
            ))) : (
              <div class="p-8 lg:p-12 text-center">
                <p class="text-muted-text text-lg">No past events to display yet.</p>
              </div>
            )}
          </div>
        </div>
      </section>

      <section class="py-20 bg-white border-t-4 border-warm-gold">
        <div class="max-w-7xl mx-auto px-6 lg:px-12 text-center">
          <div class="max-w-2xl mx-auto animate-on-scroll">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-warm-gold mx-auto mb-6"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
            <h2 class="text-4xl font-bold text-forest-green mb-6">
              Stay Updated on Upcoming Events
            </h2>
            <p class="text-lg text-muted-text mb-8 leading-relaxed">
              Subscribe to our newsletter to receive early registration access and exclusive event updates.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 max-w-xl mx-auto">
              <input
                type="email"
                placeholder="Your email address"
                 class="flex-1 px-6 py-4 border-2 border-rule-border bg-cream text-base focus:outline-none focus:border-forest-green rounded-lg"
              />
              <button class="bg-forest-green text-white px-8 py-4 text-sm uppercase tracking-wider hover:bg-warm-gold hover:text-near-black transition-all rounded-lg">
                Subscribe
              </button>
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
