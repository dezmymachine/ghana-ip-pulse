---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";

const contacts = [
  {
    label: "Email",
    value: "daagyei.law@knust.edu.gh",
    href: "mailto:daagyei.law@knust.edu.gh",
    description: "For consultations, speaking engagements, or general inquiries",
  },
  {
    label: "WhatsApp",
    value: "+233 276 414 414",
    href: "https://wa.me/233276414414",
    description: "For quick questions or workshop registrations",
  },
  {
    label: "Phone",
    value: "+233 (0) 3220 0710",
    href: "tel:+233322000710",
    description: "Office line — available during working hours",
  },
  {
    label: "LinkedIn",
    value: "linkedin.com/in/doreen-agyei-836524232",
    href: "https://www.linkedin.com/in/doreen-agyei-836524232/",
    description: "Connect for professional networking and updates",
  },
];
---

<Layout title="Contact">
  <Navigation />
  <main class="flex-1 pt-24 lg:pt-28">
    <div class="bg-cream min-h-[60vh]">
      <section class="py-16 lg:py-24">
        <div class="max-w-5xl mx-auto px-6 lg:px-12">
          <h1 class="font-heading text-4xl lg:text-5xl font-bold text-forest-green mb-4 animate-on-scroll">
            Contact
          </h1>
          <p class="text-lg lg:text-xl text-muted-text max-w-2xl mb-12 lg:mb-16 leading-relaxed animate-on-scroll" data-delay="1">
            For IP guidance, partnership opportunities, or any questions about my work, I'd be glad to hear from you. I aim to respond within 2–3 business days.
          </p>

          <div class="grid md:grid-cols-2 gap-4 lg:gap-6 mb-12 lg:mb-16">
            {contacts.map((contact, i) => (
              <a
                href={contact.href}
                target={contact.label === "LinkedIn" || contact.label === "WhatsApp" ? "_blank" : undefined}
                rel={(contact.label === "LinkedIn" || contact.label === "WhatsApp") ? "noopener noreferrer" : undefined}
                class={`group bg-white rounded-lg p-6 lg:p-8 hover:shadow-md transition-shadow flex items-start justify-between gap-4 animate-on-scroll`}
                data-delay={String(i + 1)}
              >
                <div>
                  <p class="text-xs uppercase tracking-wider text-muted-text mb-2 font-body">
                    {contact.label}:
                  </p>
                  <p class="text-lg lg:text-xl text-near-black font-medium group-hover:text-forest-green transition-colors" style="word-break: break-word;">
                    {contact.value}
                  </p>
                  <p class="text-sm text-muted-text mt-2 hidden sm:block">
                    {contact.description}
                  </p>
                </div>
                <button
                  class="copy-btn flex-shrink-0 w-9 h-9 rounded-md border border-rule-border flex items-center justify-center text-muted-text hover:text-forest-green hover:border-forest-green transition-colors"
                  data-value={contact.value}
                  aria-label={`Copy ${contact.value}`}
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
                </button>
              </a>
            ))}
          </div>

          <div class="bg-white rounded-lg p-6 lg:p-8 animate-on-scroll">
            <p class="text-xs uppercase tracking-wider text-muted-text mb-4 font-body">
              Professional Details
            </p>
            <div class="space-y-1 text-near-black leading-relaxed">
              <p class="text-base lg:text-lg">Dr Doreen Adoma Agyei</p>
              <p class="text-base lg:text-lg">Lecturer, Department of Commercial Law</p>
              <p class="text-base lg:text-lg">Kwame Nkrumah University of Science and Technology (KNUST)</p>
              <p class="text-base lg:text-lg">Kumasi, Ghana</p>
              <p class="text-sm text-muted-text mt-3">
                Vice President, IP Network Ghana &nbsp;·&nbsp; Law Practitioner at Moomin and Botta Solicitors
              </p>
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.querySelectorAll(".copy-btn").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.preventDefault();
      e.stopPropagation();
      const value = (btn as HTMLElement).dataset.value;
      if (value) {
        navigator.clipboard.writeText(value);
        const svg = btn.querySelector("svg");
        if (svg) {
          svg.innerHTML = '<polyline points="20 6 9 17 4 12"/>';
        }
        setTimeout(() => {
          if (svg) {
            svg.innerHTML = '<rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>';
          }
        }, 1500);
      }
    });
  });
</script>
