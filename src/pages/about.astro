---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import ImageWithFallback from "../components/ImageWithFallback.astro";

const founders = [
  {
    slug: "doreen-agyei",
    name: "Dr Doreen Adoma Agyei",
    role: "Co-Founder & IP Law Expert",
    image: "/headshot_1.jpeg",
    shortBio: "Dr Doreen Adoma Agyei is a distinguished intellectual property law expert and lecturer at Kwame Nkrumah University of Science and Technology (KNUST), Kumasi. With over a decade of experience in IP law and legal education, she has become a leading voice for entrepreneurs, artists, and policymakers navigating intellectual property rights in Ghana and across Africa. She holds a PhD in Intellectual Property Law from the University of Michigan and serves as Vice President of IP Network Ghana.",
  },
  {
    slug: "esther-mensah",
    name: "Esther Mensah",
    role: "Co-Founder & Strategy Lead",
    image: "/headshot_2.jpeg",
    shortBio: "Esther Mensah is an experienced innovation strategist with a passion for bridging the gap between legal frameworks and creative industries. Her work spans policy development, capacity building for startups, and advocacy for stronger IP ecosystems across West Africa. Esther brings over eight years of experience working with international development organizations and local creative enterprises to build sustainable models for intellectual property protection and commercialization.",
  },
];
---

<Layout title="About">
  <Navigation />
  <main class="flex-1 pt-5 lg:pt-6">
    <div class="bg-cream min-h-[60vh]">
      <section class="py-16 lg:py-24">
        <div class="max-w-7xl mx-auto px-6 lg:px-12">
          <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4 mb-12 lg:mb-16">
            <h1 class="font-heading text-4xl lg:text-5xl font-bold text-forest-green">
              Leadership
            </h1>
            <p class="text-lg text-muted-text max-w-xl leading-relaxed">
              Meet the founders driving Ghana's intellectual property education and advocacy forward.
            </p>
          </div>

          <div class="grid md:grid-cols-2 gap-6 lg:gap-8">
            {founders.map((founder) => (
              <article class="bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow group">
                <div class="aspect-[4/3] bg-[#D4C9B0] overflow-hidden">
                  <ImageWithFallback
                    src={founder.image}
                    alt={founder.name}
                    class="w-full h-full object-cover object-top group-hover:scale-[1.02] transition-transform duration-500"
                  />
                </div>
                <div class="p-6 lg:p-8">
                  <h2 class="font-heading text-2xl font-bold text-forest-green mb-1">
                    {founder.name}
                  </h2>
                  <p class="text-sm uppercase tracking-wider text-warm-gold font-body font-medium mb-4">
                    {founder.role}
                  </p>
                  <p class="text-muted-text leading-relaxed mb-6 line-clamp-4">
                    {founder.shortBio}
                  </p>
                  <a
                    href={`/about/${founder.slug}`}
                    class="inline-flex items-center gap-2 text-forest-green font-body font-semibold hover:text-warm-gold transition-colors text-sm"
                  >
                    Read Full Bio
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
