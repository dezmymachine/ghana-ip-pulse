---
import Layout from "../../layouts/Layout.astro";
import Navigation from "../../components/Navigation.astro";
import Footer from "../../components/Footer.astro";
import ImageWithFallback from "../../components/ImageWithFallback.astro";

const education = [
  { period: "2018 – 2024", degree: "Doctor of Pharmacy (PharmD)", institution: "Kwame Nkrumah University of Science and Technology (KNUST), Ghana" },
];

const experience = [
  { period: "2024 – Present", role: "Hospital Pharmacist (Intern/Practice Experience)", organization: "Kumasi South Hospital", details: [
    "Dispensing medications accurately and ensuring safe drug use",
    "Providing pharmaceutical interventions to optimize therapy",
    "Counseling patients on proper medication use and adherence",
    "Supporting healthcare teams in delivering effective patient care",
  ]},
];

const interests = [
  "Hospital Pharmacy Practice",
  "Public Health & Patient Education",
  "Rational Drug Use",
  "Clinical Interventions & Pharmaceutical Care",
];

const projects = [
  { title: "Participated in clinical rotations across multiple departments" },
  { title: "Contributed to patient counseling and education" },
  { title: "Assisted in resolving drug-related problems" },
  { title: "Collaborated with healthcare teams to improve outcomes" },
];

const certifications = [
  { note: "Currently building professional certifications to enhance clinical and public health expertise" },
];
---

<Layout title="Rosina Serwaa Antwi">
  <Navigation />
  <main class="flex-1 pt-24 lg:pt-28">
    <div class="bg-cream">
      <section class="py-12 lg:py-20">
        <div class="max-w-7xl mx-auto px-6 lg:px-12">
          <a href="/about" class="inline-flex items-center gap-2 text-muted-text hover:text-forest-green transition-colors text-sm mb-8 font-body">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
            Back to Leadership
          </a>

          <div class="grid lg:grid-cols-[280px_1fr] gap-10 lg:gap-16 mb-16 lg:mb-24">
            <div>
              <div class="rounded-card overflow-hidden sticky top-24 w-fit max-w-[280px] shadow-sm animate-on-scroll">
                <ImageWithFallback
                  src="/second_founder.png"
                  alt="Rosina Serwaa Antwi"
                  class="w-[280px] h-auto object-cover object-top"
                />
              </div>
            </div>

            <div>
              <p class="text-sm uppercase tracking-wider text-warm-gold font-body font-semibold mb-2 animate-on-scroll" data-delay="1">
                Co-Founder & Clinical Pharmacy Lead
              </p>
              <h1 class="font-heading text-3xl lg:text-4xl font-bold text-forest-green mb-6 animate-on-scroll" data-delay="2">
                Rosina Serwaa Antwi
              </h1>

              <div class="space-y-4 lg:space-y-6 text-base lg:text-lg text-near-black leading-relaxed mb-8 animate-on-scroll" data-delay="3">
                <p>
                  Rosina Serwaa Antwi is a dedicated Pharmacist (PharmD) with a strong focus on hospital pharmacy practice, public health, and patient-centered care. She is passionate about improving health outcomes through effective medication management, patient education, and compassionate clinical service.
                </p>
                <p>
                  With hands-on experience in hospital settings, Rosina has developed practical skills in drug dispensing, pharmaceutical care, and clinical interventions. She is deeply committed to supporting patients, particularly vulnerable populations, by ensuring safe, rational, and effective use of medicines.
                </p>
                <p>
                  Her professional interests lie in bridging the gap between clinical pharmacy and public health, with a focus on educating patients and promoting better health practices within communities. As a co-founder, she aims to contribute to innovative healthcare solutions that enhance access to quality pharmaceutical care.
                </p>
              </div>

              <div class="border-l-4 border-warm-gold pl-4 lg:pl-8 py-4 lg:py-6 bg-white rounded-r-lg animate-on-scroll" data-delay="4">
                <p class="text-lg lg:text-2xl italic text-forest-green leading-relaxed">
                  "Take care of your body the way you take care of your job."
                </p>
                <div class="mt-3 lg:mt-4 text-xs lg:text-sm uppercase tracking-wider text-muted-text">
                  — Rosina Serwaa Antwi
                </div>
              </div>
            </div>
          </div>

          <div class="mb-16 lg:mb-24">
            <h2 class="font-heading text-2xl lg:text-3xl font-bold text-forest-green mb-6 lg:mb-8 animate-on-scroll">
              Education
            </h2>
            <div class="bg-white border-2 border-rule-border rounded-lg overflow-hidden animate-on-scroll" data-delay="1">
              {education.map((edu, index) => (
                <div
                  class={`grid grid-cols-1 lg:grid-cols-[200px_1fr] gap-3 lg:gap-6 p-4 lg:p-6 ${
                    index !== education.length - 1 ? "border-b border-rule-border" : ""
                  }`}
                >
                  <div class="text-sm lg:text-base font-medium text-warm-gold">
                    {edu.period}
                  </div>
                  <div>
                    <div class="text-base lg:text-lg text-near-black font-medium">
                      {edu.degree}
                    </div>
                    <div class="text-sm lg:text-base text-muted-text">
                      {edu.institution}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="mb-16 lg:mb-24">
            <h2 class="font-heading text-2xl lg:text-3xl font-bold text-forest-green mb-6 lg:mb-8 animate-on-scroll">
              Work Experience
            </h2>
            <div class="bg-white border-2 border-rule-border rounded-lg overflow-hidden animate-on-scroll" data-delay="1">
              {experience.map((exp, index) => (
                <div
                  class={`p-4 lg:p-6 ${
                    index !== experience.length - 1 ? "border-b border-rule-border" : ""
                  }`}
                >
                  <div class="text-sm lg:text-base font-medium text-warm-gold mb-1">
                    {exp.period}
                  </div>
                  <div class="text-base lg:text-lg text-near-black font-medium">
                    {exp.role}
                  </div>
                  <div class="text-sm lg:text-base text-muted-text mb-3">
                    {exp.organization}
                  </div>
                  {exp.details && (
                    <ul class="list-disc list-inside space-y-1 text-sm lg:text-base text-muted-text">
                      {exp.details.map((detail) => (
                        <li>{detail}</li>
                      ))}
                    </ul>
                  )}
                </div>
              ))}
            </div>
          </div>

          <div class="mb-16 lg:mb-24">
            <h2 class="font-heading text-2xl lg:text-3xl font-bold text-forest-green mb-6 lg:mb-8 animate-on-scroll">
              Key Areas of Interest
            </h2>
            <div class="bg-white border-2 border-rule-border rounded-lg overflow-hidden animate-on-scroll" data-delay="1">
              {interests.map((interest, index) => (
                <div
                  class={`p-4 lg:p-6 ${
                    index !== interests.length - 1 ? "border-b border-rule-border" : ""
                  }`}
                >
                  <div class="text-base lg:text-lg text-near-black font-medium">
                    {interest}
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="mb-16 lg:mb-24">
            <h2 class="font-heading text-2xl lg:text-3xl font-bold text-forest-green mb-6 lg:mb-8 animate-on-scroll">
              Key Projects & Contributions
            </h2>
            <div class="bg-white border-2 border-rule-border rounded-lg overflow-hidden animate-on-scroll" data-delay="1">
              {projects.map((project, index) => (
                <div
                  class={`p-4 lg:p-6 ${
                    index !== projects.length - 1 ? "border-b border-rule-border" : ""
                  }`}
                >
                  <div class="text-base lg:text-lg text-near-black font-medium" style="word-break: break-word;">
                    {project.title}
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="mb-16 lg:mb-24">
            <h2 class="font-heading text-2xl lg:text-3xl font-bold text-forest-green mb-6 lg:mb-8 animate-on-scroll">
              Certifications
            </h2>
            <div class="bg-white border-2 border-rule-border rounded-lg overflow-hidden animate-on-scroll" data-delay="1">
              {certifications.map((cert, index) => (
                <div class="p-4 lg:p-6">
                  <div class="text-base lg:text-lg text-muted-text">
                    {cert.note}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
