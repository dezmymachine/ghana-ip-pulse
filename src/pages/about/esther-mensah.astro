---
import Layout from "../../layouts/Layout.astro";
import Navigation from "../../components/Navigation.astro";
import Footer from "../../components/Footer.astro";
import ImageWithFallback from "../../components/ImageWithFallback.astro";

const education = [
  { period: "2018-2020", degree: "MSc in Innovation & Strategy", institution: "University of Cambridge, UK" },
  { period: "2014-2018", degree: "BSc in Business Administration", institution: "University of Ghana, Legon" },
  { period: "2019", degree: "Certificate in IP Management", institution: "World Intellectual Property Organization (WIPO)" },
  { period: "2021", degree: "Executive Certificate in Creative Industries Policy", institution: "British Council & University of London" },
];

const experience = [
  { period: "2022 - Date", role: "Co-Founder & Strategy Lead", organization: "IP Ghana Initiative" },
  { period: "2019-2022", role: "Innovation Consultant", organization: "Ministry of Trade & Industry, Ghana" },
  { period: "2017-2019", role: "Program Associate", organization: "African Development Bank — Creative Sector Desk" },
  { period: "2015-2017", role: "Research Analyst", organization: "Ghana Investment Promotion Centre" },
];

const projects = [
  { year: "2024", title: "Creative Ghana IP Framework — National policy proposal for creative sector IP protection" },
  { year: "2023", title: "Startup IP Toolkit — Open-access resource for Ghanaian startups on trademark and copyright basics" },
  { year: "2022", title: "West Africa IP Summit — Regional convening bringing together policymakers, creatives, and legal experts" },
  { year: "2021", title: "Artisan Heritage Project — Pilot program documenting and protecting traditional Kente weaving IP rights" },
];
---

<Layout title="Esther Mensah">
  <Navigation />
  <main class="flex-1 pt-5 lg:pt-6">
    <div class="bg-cream">
      <section class="py-12 lg:py-20">
        <div class="max-w-7xl mx-auto px-6 lg:px-12">
          <a href="/about" class="inline-flex items-center gap-2 text-muted-text hover:text-forest-green transition-colors text-sm mb-8 font-body">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
            Back to Leadership
          </a>

          <div class="grid lg:grid-cols-[280px_1fr] gap-10 lg:gap-16 mb-16 lg:mb-24">
            <div>
              <div class="border-2 border-forest-green rounded-card overflow-hidden sticky top-24 w-fit max-w-[280px]">
                <ImageWithFallback
                  src="/second_founder.png"
                  alt="Esther Mensah"
                  class="w-[280px] h-auto object-cover object-top"
                />
              </div>
            </div>

            <div>
              <p class="text-sm uppercase tracking-wider text-warm-gold font-body font-semibold mb-2">
                Co-Founder & Strategy Lead
              </p>
              <h1 class="font-heading text-3xl lg:text-4xl font-bold text-forest-green mb-6">
                Esther Mensah
              </h1>

              <div class="space-y-4 lg:space-y-6 text-base lg:text-lg text-near-black leading-relaxed mb-8">
                <p>
                  Esther Mensah is an experienced innovation strategist with a deep passion for bridging the gap between legal frameworks and creative industries. Her work spans policy development, capacity building for early-stage startups, and advocacy for stronger intellectual property ecosystems across West Africa.
                </p>
                <p>
                  With over eight years of experience working alongside international development organizations and local creative enterprises, Esther has developed sustainable models for intellectual property protection and commercialization that are tailored specifically to the Ghanaian context. She believes that every innovator—whether a Kente weaver in Bonwire or a software developer in Accra—deserves clear, accessible pathways to protect their work.
                </p>
                <p>
                  Prior to co-founding this initiative, Esther served as an Innovation Consultant at Ghana's Ministry of Trade and Industry, where she led cross-functional teams on creative economy policy design. She has also worked with the African Development Bank's Creative Sector Desk, supporting programs that connect African creators with global markets while safeguarding their intellectual property rights.
                </p>
                <p>
                  Esther holds an MSc in Innovation and Strategy from the University of Cambridge and a BSc in Business Administration from the University of Ghana. She is a certified IP Management professional through WIPO Academy and regularly speaks at regional forums on the intersection of innovation policy, creative economies, and intellectual property rights.
                </p>
              </div>

              <div class="border-l-4 border-warm-gold pl-4 lg:pl-8 py-4 lg:py-6 bg-white rounded-r-lg">
                <p class="text-lg lg:text-2xl italic text-forest-green leading-relaxed">
                  "When we make IP protection simple and accessible, we don't just protect ideas—we unlock entire industries."
                </p>
                <div class="mt-3 lg:mt-4 text-xs lg:text-sm uppercase tracking-wider text-muted-text">
                  — Esther Mensah
                </div>
              </div>
            </div>
          </div>

          <div class="mb-16 lg:mb-24">
            <h2 class="font-heading text-2xl lg:text-3xl font-bold text-forest-green mb-6 lg:mb-8">
              Education
            </h2>
            <div class="bg-white border-2 border-rule-border rounded-lg overflow-hidden">
              {education.map((edu, index) => (
                <div
                  class={`grid grid-cols-1 lg:grid-cols-[200px_1fr] gap-3 lg:gap-6 p-4 lg:p-6 ${
                    index !== education.length - 1 ? "border-b border-rule-border" : ""
                  }`}
                >
                  <div class="text-sm lg:text-base font-medium text-warm-gold">
                    {edu.period}
                  </div>
                  <div>
                    <div class="text-base lg:text-lg text-near-black font-medium">
                      {edu.degree}
                    </div>
                    <div class="text-sm lg:text-base text-muted-text">
                      {edu.institution}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="mb-16 lg:mb-24">
            <h2 class="font-heading text-2xl lg:text-3xl font-bold text-forest-green mb-6 lg:mb-8">
              Work Experience
            </h2>
            <div class="bg-white border-2 border-rule-border rounded-lg overflow-hidden">
              {experience.map((exp, index) => (
                <div
                  class={`grid grid-cols-1 lg:grid-cols-[180px_1fr] gap-3 lg:gap-6 p-4 lg:p-6 ${
                    index !== experience.length - 1 ? "border-b border-rule-border" : ""
                  }`}
                >
                  <div class="text-sm lg:text-base font-medium text-warm-gold">
                    {exp.period}
                  </div>
                  <div>
                    <div class="text-base lg:text-lg text-near-black font-medium">
                      {exp.role}
                    </div>
                    <div class="text-sm lg:text-base text-muted-text">
                      {exp.organization}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="mb-16 lg:mb-24">
            <h2 class="font-heading text-2xl lg:text-3xl font-bold text-forest-green mb-6 lg:mb-8">
              Key Projects
            </h2>
            <div class="bg-white border-2 border-rule-border rounded-lg overflow-hidden">
              {projects.map((project, index) => (
                <div
                  class={`grid grid-cols-1 lg:grid-cols-[100px_1fr] gap-3 lg:gap-6 p-4 lg:p-6 ${
                    index !== projects.length - 1 ? "border-b border-rule-border" : ""
                  }`}
                >
                  <div class="text-sm lg:text-base font-medium text-warm-gold">
                    {project.year}
                  </div>
                  <div>
                    <div class="text-base lg:text-lg text-near-black font-medium" style="word-break: break-word;">
                      {project.title}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
