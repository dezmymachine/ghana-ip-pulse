---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import ImageWithFallback from "../components/ImageWithFallback.astro";
import { loadQuery } from "../sanity/lib/load-query";
import { urlForImage } from "../sanity/lib/url-for-image";

const { data: featuredArticles } = await loadQuery<any[]>({
  query: `*[_type == "post"] | order(publishedAt desc)[0..2] {
    title,
    slug,
    publishedAt,
    excerpt,
    mainImage,
    categories[]->{ title }
  }`,
});

const formatDate = (dateString: string) => {
  const date = new Date(dateString);
  return date.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" });
};

const getImageUrl = (image: any) => {
  if (!image) return null;
  try {
    return urlForImage(image).width(800).url();
  } catch (e) {
    return null;
  }
};

const topics = [
  {
    title: "IP for Entrepreneurs",
    description: "Trademark, patent, and trade secret protection for your business ventures.",
    image: "https://images.unsplash.com/photo-1556761175-5973dc0f32e7?w=600",
    link: "/blog",
  },
  {
    title: "IP for Creatives",
    description: "Copyright registration and enforcement for musicians, artists, and content creators.",
    image: "https://images.unsplash.com/photo-1513364776144-60967b0f800f?w=600",
    link: "/blog",
  },
  {
    title: "IP for Students",
    description: "Educational resources and research guidance for aspiring IP professionals.",
    image: "https://images.unsplash.com/photo-1523240795612-9a054b0db644?w=600",
    link: "/resources",
  },
];
---

<Layout title="Home">
  <Navigation />
  <main class="flex-1 pt-24 lg:pt-28">
    <section class="bg-forest-green relative overflow-hidden pt-16 lg:pt-24">
      <div class="max-w-7xl mx-auto">
        <div class="grid lg:grid-cols-[45%_55%]">
          <div class="px-6 lg:px-12 pb-6 lg:pb-32 flex flex-col justify-end min-h-[300px] lg:min-h-[500px]">
            <h1 class="font-heading text-white font-bold leading-[1.15] mb-4" style="font-size: clamp(32px, 4vw, 48px);">
              Protecting Ghana's Ideas, One Conversation at a Time
            </h1>
            
            <p class="font-body text-base text-white/70 mb-6 max-w-sm">
              Expert guidance on intellectual property law for entrepreneurs, creatives, and students navigating Ghana's innovation landscape.
            </p>
            
            <a
              href="/blog"
              class="inline-flex items-center gap-2 bg-warm-gold text-near-black px-5 py-2.5 rounded-pill font-body font-semibold hover:bg-[#9A7209] transition-colors text-sm w-fit"
            >
              Explore Articles
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
          
          <div class="relative h-[280px] lg:h-full min-h-[280px] lg:min-h-[500px] lg:min-h-[600px]">
            <div class="absolute inset-0 w-full h-full">
              <div class="absolute inset-0 bg-gradient-to-t from-forest-green via-transparent to-transparent z-10"></div>
              <img 
                src="/headshot.png" 
                alt="Dr Doreen Adoma Agyei"
                class="absolute inset-0 w-full h-full object-cover object-top"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-cream py-20 lg:py-28">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="mb-16">
          <div class="inline-flex items-center gap-2 border border-forest-green/30 text-forest-green px-4 py-2 rounded-pill text-sm font-body mb-6">
            What You'll Learn
          </div>
          
          <div class="grid lg:grid-cols-2 gap-8 items-end">
            <div>
              <h2 class="font-heading text-4xl lg:text-5xl font-bold text-forest-green">
                IP Topics You Can Trust
              </h2>
            </div>
            <div class="flex items-start lg:justify-end gap-6">
              <p class="font-body text-muted-text max-w-sm leading-relaxed">
                Practical guidance on intellectual property law tailored for Ghana's creative and business community.
              </p>
              <div class="flex gap-2 flex-shrink-0">
                <button id="prev-btn" class="w-10 h-10 rounded-full border border-forest-green/20 flex items-center justify-center text-forest-green hover:bg-forest-green hover:text-white transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                </button>
                <button id="next-btn" class="w-10 h-10 rounded-full border border-forest-green/20 flex items-center justify-center text-forest-green hover:bg-forest-green hover:text-white transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </button>
              </div>
            </div>
          </div>
        </div>

        <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
          {topics.map((topic) => (
            <a
              href={topic.link}
              class="group bg-white rounded-card shadow-lg hover:shadow-xl transition-all overflow-hidden"
            >
              <div class="aspect-[4/3] overflow-hidden">
                <ImageWithFallback
                  src={topic.image}
                  alt={topic.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              </div>
              <div class="p-6">
                <h3 class="font-heading text-xl font-bold text-forest-green mb-2 group-hover:text-warm-gold transition-colors">
                  {topic.title}
                </h3>
                <p class="font-body text-muted-text text-sm leading-relaxed">
                  {topic.description}
                </p>
              </div>
            </a>
          ))}
        </div>

        <div class="text-center mt-12">
          <a
            href="/resources"
            class="inline-flex items-center gap-2 bg-warm-gold text-white px-8 py-4 rounded-pill font-body font-semibold hover:bg-[#9A7209] transition-colors"
          >
            Explore All Resources
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>

    <section class="bg-white py-20 lg:py-28">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="text-center mb-16">
          <div class="inline-flex items-center gap-2 border border-forest-green/30 text-forest-green px-4 py-2 rounded-pill text-sm font-body mb-6">
            Latest Insights
          </div>
          <h2 class="font-heading text-4xl lg:text-5xl font-bold text-forest-green">
            Recent Articles
          </h2>
        </div>

        <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
          {featuredArticles?.map((article: any) => (
            <article class="group bg-cream rounded-card overflow-hidden hover:shadow-lg transition-all">
              <div class="aspect-[16/9] overflow-hidden">
                <ImageWithFallback
                  src={getImageUrl(article.mainImage) || "https://images.unsplash.com/photo-1625191824973-894292e94c96?w=800"}
                  alt={article.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              </div>
              <div class="p-6">
                <div class="mb-3">
                  <span class="inline-block bg-warm-gold/10 text-warm-gold px-3 py-1 rounded-pill text-xs font-body font-medium">
                    {article.categories?.[0]?.title || "Article"}
                  </span>
                </div>
                <h3 class="font-heading text-lg font-bold text-forest-green mb-2 group-hover:text-warm-gold transition-colors">
                  <a href={`/blog/${article.slug.current}`}>{article.title}</a>
                </h3>
                <p class="font-body text-muted-text text-sm leading-relaxed mb-4 line-clamp-2">
                  {article.excerpt}
                </p>
                <div class="flex items-center justify-between text-xs font-body text-muted-text">
                  <span>{article.publishedAt ? formatDate(article.publishedAt) : ""}</span>
                  <a href={`/blog/${article.slug.current}`} class="text-warm-gold hover:underline">Read more</a>
                </div>
              </div>
            </article>
          ))}
        </div>

        <div class="text-center mt-12">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 text-forest-green font-body font-semibold hover:text-warm-gold transition-colors group"
          >
            View All Articles
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>

    <section class="bg-forest-green py-20">
      <div class="max-w-4xl mx-auto px-6 lg:px-12 text-center">
        <h2 class="font-heading text-3xl lg:text-4xl font-bold text-white mb-4">
          Have a Question About IP Law?
        </h2>
        <p class="font-body text-lg text-white/70 mb-8 max-w-xl mx-auto">
          Schedule a consultation or reach out to discuss your intellectual property needs.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 bg-warm-gold text-white px-8 py-4 rounded-pill font-body font-semibold hover:bg-[#9A7209] transition-colors"
        >
          Get in Touch
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
